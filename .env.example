# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://opensales:opensales_secret@localhost:5432/opensales"

# PostgreSQL credentials (used by Docker Compose)
POSTGRES_USER=opensales
POSTGRES_PASSWORD=opensales_secret
POSTGRES_DB=opensales

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 64
JWT_SECRET="change-me-generate-with-openssl-rand-base64-64"

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# ─── MinIO (S3-compatible file storage) ──────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT="http://localhost:9000"
MINIO_BUCKET=opensales

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Bring your own SMTP server (Gmail, Mailgun, Postmark, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM="OpenSales Navigator <noreply@example.com>"

# ─── Enrichment APIs (Phase 2) ────────────────────────────────────────────────
# CLEARBIT_API_KEY=
# HUNTER_API_KEY=
# APOLLO_API_KEY=

# ─── CRM Integrations (Phase 3) ──────────────────────────────────────────────
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
